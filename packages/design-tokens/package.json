{
  "name": "@rafters/design-tokens",
  "private": true,
  "version": "0.0.0",
  "description": "Design token system. Zod-schema-first. Pure infrastructure: storage, DAG, cascade, plugin protocol, persistence. Domain code (color, motion, typography) lives in dedicated packages.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo coverage"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rafters/design-tokens-v1": "workspace:*",
    "@rafters/shared": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
