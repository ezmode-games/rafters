@layer base {
  article p {
    @apply leading-relaxed mb-4;
  }
  article p:last-child {
    @apply mb-0;
  }
  article h1 {
    @apply text-4xl font-bold tracking-tight mb-4 mt-0 text-accent-foreground;
  }
  article h2 {
    @apply text-3xl font-semibold tracking-tight mb-3 mt-8 text-accent-foreground;
  }
  article h2:first-child {
    @apply mt-0;
  }
  article h3 {
    @apply text-2xl font-semibold mb-2 mt-6 text-accent-foreground;
  }
  article h4 {
    @apply text-xl font-semibold mb-2 mt-4 text-accent-foreground;
  }
  article h5 {
    @apply text-lg font-semibold mb-2 mt-4 text-accent-foreground;
  }
  article h6 {
    @apply text-base font-semibold mb-2 mt-4 text-accent-foreground;
  }
  article ul {
    @apply list-disc pl-6 mb-4;
  }
  article ol {
    @apply list-decimal pl-6 mb-4;
  }
  article li {
    @apply mb-1;
  }
  article li > ul,
  article li > ol {
    @apply mt-1 mb-0;
  }
  article a {
    @apply text-primary underline underline-offset-4;
  }
  article a:hover {
    @apply text-primary/80;
  }
  article blockquote {
    @apply border-l-4 border-muted pl-4 italic my-4;
  }
  article code {
    @apply bg-muted px-1.5 py-0.5 rounded text-sm font-mono;
  }
  article pre {
    @apply bg-muted p-4 rounded-lg overflow-x-auto my-4 text-sm font-mono;
  }
  article pre code {
    @apply bg-transparent p-0 rounded-none text-[inherit];
  }
  article kbd {
    @apply bg-muted border border-border rounded px-1.5 py-0.5 text-sm font-mono;
  }
  article hr {
    @apply border-border my-8;
  }
  article img {
    @apply rounded-lg my-4 max-w-full h-auto;
  }
  article video {
    @apply rounded-lg my-4 max-w-full h-auto;
  }
  article table {
    @apply w-full my-4 border-collapse;
  }
  article caption {
    @apply mt-2 text-sm text-muted-foreground text-left;
  }
  article th {
    @apply border border-border px-3 py-2 text-left font-semibold;
  }
  article td {
    @apply border border-border px-3 py-2;
  }
  article figure {
    @apply my-4;
  }
  article figcaption {
    @apply mt-2 text-sm text-muted-foreground;
  }
  article dl {
    @apply my-4;
  }
  article dt {
    @apply font-semibold mt-2;
  }
  article dd {
    @apply pl-4 mb-2;
  }
  article details {
    @apply my-4;
  }
  article summary {
    @apply cursor-pointer font-semibold;
  }
  article strong,
  article b {
    @apply font-semibold;
  }
  article mark {
    @apply bg-accent text-accent-foreground px-1 rounded;
  }
  article small {
    @apply text-sm;
  }
  article sub {
    @apply text-xs align-sub;
  }
  article sup {
    @apply text-xs align-super;
  }
  article abbr[title] {
    @apply underline decoration-dotted underline-offset-4 cursor-help;
  }
  article s,
  article del {
    @apply line-through;
  }
  article ins {
    @apply underline;
  }
}"
`;

exports[`exporter byte-shape > TypeScript const exports match snapshot 1`] = `
"/* Generated by Rafters - DO NOT EDIT */

export const tokens = {
  breakpoint: {
    'breakpoint-md': '768px',
  },
  color: {
    'accent': 'oklch(0.550 0.180 240.0)',
    'gray': 'oklch(0.500 0.005 0.0)',
  },
  motion: {
    'motion-duration-base': '150ms',
    'motion-easing-productive': 'cubic-bezier(0.4, 0, 0.2, 1)',
  },
  radius: {
    'radius-base': '4px',
    'radius-lg': '8px',
  },
  semantic: {
    'primary': 'var(--color-accent-500)',
    'primary-foreground': 'var(--color-gray-50)',
    'primary-hover': 'var(--color-accent-600)',
  },
  shadow: {
    'shadow-sm': '0 1px 2px rgba(0, 0, 0, 0.05)',
  },
  spacing: {
    'spacing-base': '4px',
    'spacing-2': '8px',
    'spacing-4': '16px',
  },
  typography: {
    'typography-font-size-base': '1rem',
    'typography-font-weight-bold': '700',
  },
} as const;

export type TokenNamespace = keyof typeof tokens;

export type BreakpointToken = keyof typeof tokens.breakpoint;
export type ColorToken = keyof typeof tokens.color;
export type MotionToken = keyof typeof tokens.motion;
export type RadiusToken = keyof typeof tokens.radius;
export type SemanticToken = keyof typeof tokens.semantic;
export type ShadowToken = keyof typeof tokens.shadow;
export type SpacingToken = keyof typeof tokens.spacing;
export type TypographyToken = keyof typeof tokens.typography;

export type TokenName =
  | BreakpointToken
  | ColorToken
  | MotionToken
  | RadiusToken
  | SemanticToken
  | ShadowToken
  | SpacingToken
  | TypographyToken;

/** Get a token value by namespace and name */
export function getToken<N extends TokenNamespace>(
  namespace: N,
  name: keyof typeof tokens[N]
): (typeof tokens)[N][typeof name] {
  return tokens[namespace][name];
}
"
`;
