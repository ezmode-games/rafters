---
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { type CardBackground, cardBackgroundClasses, cardTitleClasses } from './card.classes';

type HeadingLevel = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';

interface Props extends HTMLAttributes<'h3'> {
  as?: HeadingLevel;
  background?: CardBackground;
}

const { as: Tag = 'h3', background, class: className, ...attrs } = Astro.props;
const bgStyles = background ? cardBackgroundClasses[background] : '';
const cls = classy(cardTitleClasses, bgStyles, className);
---

<Tag class={cls} {...attrs}>
  <slot />
</Tag>
