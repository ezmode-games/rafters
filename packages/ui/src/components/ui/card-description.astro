---
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { type CardBackground, cardBackgroundClasses, cardDescriptionClasses } from './card.classes';

interface Props extends HTMLAttributes<'p'> {
  background?: CardBackground;
}

const { background, class: className, ...attrs } = Astro.props;
const bgStyles = background ? cardBackgroundClasses[background] : '';
const cls = classy(cardDescriptionClasses, bgStyles, className);
---

<p class={cls} {...attrs}>
  <slot />
</p>
