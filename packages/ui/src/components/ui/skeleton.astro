---
/**
 * Skeleton loading placeholder component (Astro)
 *
 * Zero client JavaScript. CSS-only animation with reduced motion support.
 *
 * @cognitive-load 1/10
 * @accessibility motion-reduce respects prefers-reduced-motion, aria-hidden decorative
 */
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';

export type SkeletonVariant =
  | 'default'
  | 'primary'
  | 'secondary'
  | 'destructive'
  | 'success'
  | 'warning'
  | 'info'
  | 'muted'
  | 'accent';

interface Props extends HTMLAttributes<'div'> {
  variant?: SkeletonVariant;
}

const { variant = 'default', class: className, ...attrs } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-muted',
  primary: 'bg-primary-subtle',
  secondary: 'bg-secondary-subtle',
  destructive: 'bg-destructive-subtle',
  success: 'bg-success-subtle',
  warning: 'bg-warning-subtle',
  info: 'bg-info-subtle',
  muted: 'bg-muted',
  accent: 'bg-accent-subtle',
};

const cls = classy(
  'rounded-md animate-pulse motion-reduce:animate-none',
  variantClasses[variant] ?? variantClasses.default,
  className,
);
---

<div class={cls} {...attrs} />
