---
import type { HTMLAttributes } from 'astro/types';
import classy from '../../primitives/classy';
import { type CardBackground, cardActionClasses, cardBackgroundClasses } from './card.classes';

interface Props extends HTMLAttributes<'div'> {
  background?: CardBackground;
}

const { background, class: className, ...attrs } = Astro.props;
const bgStyles = background ? cardBackgroundClasses[background] : '';
const cls = classy(cardActionClasses, bgStyles, className);
---

<div data-slot="card-action" class={cls} {...attrs}>
  <slot />
</div>
